extends ../layout

block content

   h2(class='ls-title') PAdES Signature using CloudHub with REST PKI Core

   p File signed successfully!

   h3 Actions:
   ul
      li
         a(href=`/download?fileId=${signedPdf}`, target='_blank') Download the signed file
      li
         a(href=`/printer-version-pades-core?fileId=${signedPdf}`, target='_blank') Download a printer-friendly version of the signed file
      li
         a(href=`/open-pades-core?fileId=${signedPdf}`) Open/validate the signed file
      li
         a(href=`/pades-signature-cloudhub-core?fileId=${signedPdf}`) Co-sign with another certificate
